# ─────────────────────────────────────────────────────────────────────────────
# This app works with ANY LangChain-compatible LLM provider.
# Set at least one key below. The first available key is used as the default.
# ─────────────────────────────────────────────────────────────────────────────

# RECOMMENDED: Google Gemini (free tier — 1,500 req/day, no credit card needed)
# Sign up at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key_here

# Groq — pay-as-you-go (no free tier; requires prepaid balance)
# Sign up at https://console.groq.com
# GROQ_API_KEY=your_groq_key_here

# OpenAI — paid
# OPENAI_API_KEY=your_openai_key_here

# Anthropic Claude — paid
# ANTHROPIC_API_KEY=your_anthropic_key_here
